// shadow_depth.vert.metal.msl — Shadow Depth Vertex (Metal)
#include <metal_stdlib>
using namespace metal;
struct ShadowUBO{float4x4 model,lightViewProj;float ndcZScale,ndcZOffset;float2 pad;};
struct VSIn{float3 pos[[attribute(0)]];};
vertex float4 shadowVert(VSIn v[[stage_in]],constant ShadowUBO& u[[buffer(0)]]){
    float4 wp=u.model*float4(v.pos,1.0);
    float4 p=u.lightViewProj*wp;
    p.z=p.z*u.ndcZScale+p.w*u.ndcZOffset;
    return p;
}
