// decal.vert.metal.msl — Decal Vertex (Metal)
#include <metal_stdlib>
using namespace metal;
struct CamUBO{float4x4 view,proj,viewProj,invViewProj;float4 camPos,camDir;float2 vp;float time,dt;};
struct DecalUBO{float4x4 decalMatrix;float opacity,normalBlend;float _p[2];};
struct VSIn{float3 pos[[attribute(0)]];};
struct VSOut{float4 pos[[position]];float3 decalPos;};
vertex VSOut decalVert(VSIn v[[stage_in]],constant CamUBO& cam[[buffer(0)]],constant DecalUBO& d[[buffer(1)]]){VSOut o;float4 wp=d.decalMatrix*float4(v.pos,1.f);o.decalPos=v.pos*.5f+.5f;o.pos=cam.viewProj*wp;return o;}
