// toon.vert.metal.msl — Toon Vertex (Metal)
#include <metal_stdlib>
using namespace metal;
struct CamUBO{float4x4 view,proj,viewProj,invViewProj;float4 camPos,camDir;float2 vp;float time,dt;};
struct ObjUBO{float4x4 model,normalMatrix;float4 tint;float metallic,roughness,aoStr,emissStr,normStr,clearcoat,ccRough,sss;float4 sssColor;};
struct VSIn{float3 pos[[attribute(0)]];float3 normal[[attribute(1)]];float2 uv[[attribute(3)]];float4 color[[attribute(5)]];};
struct VSOut{float4 pos[[position]];float3 worldPos;float3 normal;float2 uv;float4 color;};
vertex VSOut toonVert(VSIn v[[stage_in]],constant CamUBO& cam[[buffer(0)]],constant ObjUBO& obj[[buffer(1)]]){VSOut o;float4 wp=obj.model*float4(v.pos,1.);o.worldPos=wp.xyz;float3x3 nm=float3x3(obj.normalMatrix[0].xyz,obj.normalMatrix[1].xyz,obj.normalMatrix[2].xyz);o.normal=normalize(nm*v.normal);o.uv=v.uv;o.color=v.color*obj.tint;o.pos=cam.viewProj*wp;return o;}
