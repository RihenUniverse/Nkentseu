// trail.vert.metal.msl — Trail Ribbon Vertex (Metal)
#include <metal_stdlib>
using namespace metal;
struct CamUBO{float4x4 view,proj,viewProj,invViewProj;float4 camPos,camDir;float2 vp;float time,dt;};
struct VSIn{float3 pos[[attribute(0)]];float2 uv[[attribute(1)]];float4 color[[attribute(2)]];};
struct VSOut{float4 pos[[position]];float2 uv;float4 color;};
vertex VSOut trailVert(VSIn v[[stage_in]],constant CamUBO& cam[[buffer(0)]]){VSOut o;o.pos=cam.viewProj*float4(v.pos,1.f);o.uv=v.uv;o.color=v.color;return o;}
