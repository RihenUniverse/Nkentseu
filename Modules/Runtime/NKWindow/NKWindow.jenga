#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
NKWindow Ã¢â‚¬â€ FenÃƒÂªtrage, ÃƒÂ©vÃƒÂ©nements, entrÃƒÂ©es (C++17)
==================================================
BibliothÃƒÂ¨que principale du framework. GÃƒÂ¨re la fenÃƒÂªtre, les entrÃƒÂ©es
et le systÃƒÂ¨me d'ÃƒÂ©vÃƒÂ©nements. Le rendu est dÃƒÂ©lÃƒÂ©guÃƒÂ© ÃƒÂ  NKRenderer.

Pas de PIMPL : NkWindow et NkEventSystem sont des classes concrÃƒÂ¨tes
dont les membres platform-spÃƒÂ©cifiques sont embarquÃƒÂ©s via #ifdef.

Architecture :
  NkWindow        Ã¢â€ â€™ crÃƒÂ©e la fenÃƒÂªtre native + ÃƒÂ©met NkWindowId
  NkEventSystem   Ã¢â€ â€™ singleton, carte NkWindowIdÃ¢â€ â€™NkWindow*
  NkWindowPaintEvent Ã¢â€ â€™ signal pour que NKRenderer effectue le blit
"""

from Jenga import *
import os
import shutil
import subprocess

_THIS_DIR = os.path.dirname(__file__) if "__file__" in globals() else "."
_WAYLAND_XDG_PRIVATE_CODE = os.path.join(
    _THIS_DIR, "src", "NKWindow", "Platform", "Wayland", "xdg-shell-protocol.c"
)

def _pkg_exists(pkg_name: str) -> bool:
    if not shutil.which("pkg-config"):
        return False
    try:
        return subprocess.call(
            ["pkg-config", "--exists", pkg_name],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        ) == 0
    except Exception:
        return False

_HAS_LIBDECOR = _pkg_exists("libdecor-0")
_WAYLAND_LINKS = ["pthread", "wayland-client", "wayland-egl", "xkbcommon", "wayland-cursor", "EGL"]
_WAYLAND_TEST_LINKS = ["pthread", "wayland-client", "wayland-egl", "xkbcommon", "EGL"]
_WAYLAND_DEFINES = ["NKENTSEU_FORCE_WINDOWING_WAYLAND_ONLY"]
if _HAS_LIBDECOR:
    _WAYLAND_LINKS.append("decor-0")
    _WAYLAND_TEST_LINKS.append("decor-0")
    _WAYLAND_DEFINES.append("NKENTSEU_WAYLAND_LIBDECOR")

_TC_WINDOWS = "nk-windows-clang-mingw"

with project("NKWindow"):
    staticlib()
    language("C++")
    cppdialect("C++17")
    location(".")

    includedirs([
        "src",
        "pch",
        "%{wks.location}/Externals",
        "%{NKPlatform.location}/src",
        "%{NKCore.location}/src",
        "%{NKLogger.location}/src",
        "%{NKMath.location}/src",
        "%{NKTime.location}/src",
        "%{NKContainers.location}/src",
        "%{NKMemory.location}/src",
    ])
    pchheader("pch/pch.h")
    pchsource("pch/pch.cpp")

    dependson(["NKPlatform", "NKCore", "NKLogger", "NKMath", "NKTime", "NKContainers", "NKMemory"])

    # Fichiers communs (Core + Events Ã¢â‚¬â€ partagÃƒÂ©s par toutes les plateformes)
    files([
        "src/NKWindow/Core/**.cpp",
        "src/NKWindow/Core/**.h",
        "src/NKWindow/Events/**.cpp",
        "src/NKWindow/Events/**.h",
    ])

    objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}/%{prj.name}")
    targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}")

    with filter("system:Windows && options:windows-runtime=uwp"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-uwp/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-uwp")

    # ===== Windows ================================================================
    with filter("system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne"):
        usetoolchain(_TC_WINDOWS)
        defines([
            "WIN32_LEAN_AND_MEAN",
            "_UNICODE",
            "UNICODE",
        ])
        files([
            "src/NKWindow/Platform/Win32/**.cpp",
            "src/NKWindow/Platform/Win32/**.h",
        ])
        links([
            "user32", "gdi32", "opengl32", "dwmapi", "shell32",
            "xinput", "mf", "mfplat", "mfreadwrite", "mfuuid",
            "uuid", "ole32", "dinput8", "dxguid"
        ])

    # ===== Linux headless / NOOP ==================================================
    with filter("system:Linux && options:linux-backend=headless || system:Linux && options:headless"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-headless/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-headless")
        defines(["NKENTSEU_FORCE_WINDOWING_NOOP_ONLY"])
        files([
            "src/NKWindow/Platform/Linux/**.h",
            "src/NKWindow/Platform/Noop/NkNoopWindow.cpp",
            "src/NKWindow/Platform/Noop/NkNoopEventSystem.cpp",
            "src/NKWindow/Platform/Noop/NkNoopWindow.h",
            "src/NKWindow/Platform/Noop/NkNoopEventSystem.h",
            "src/NKWindow/Platform/Noop/NkNoopGamepad.h",
        ])
        links(["pthread"])

    # ===== Linux XLib (dÃƒÂ©faut) ====================================================
    with filter("system:Linux && options:linux-backend=xlib || system:Linux && !options:linux-backend && !options:headless"):
        files([
            "src/NKWindow/Platform/Linux/**.h",
            "src/NKWindow/Platform/XLib/**.cpp",
            "src/NKWindow/Platform/XLib/**.h",
        ])
        links(["pthread", "X11", "GL"])
        defines(["NKENTSEU_FORCE_WINDOWING_XLIB_ONLY"])

    # ===== Linux XCB ==============================================================
    with filter("system:Linux && options:linux-backend=xcb"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-xcb/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-xcb")
        files([
            "src/NKWindow/Platform/Linux/**.h",
            "src/NKWindow/Platform/XCB/**.cpp",
            "src/NKWindow/Platform/XCB/**.h",
        ])
        links(["pthread", "xcb", "xcb-image", "xcb-icccm", "xcb-randr", "xcb-xfixes", "X11-xcb", "xkbcommon", "xkbcommon-x11", "GL"])
        defines(["NKENTSEU_FORCE_WINDOWING_XCB_ONLY"])

    # ===== Linux Wayland ==========================================================
    with filter("system:Linux && options:linux-backend=wayland"):
        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-wayland/%{prj.name}")
        targetdir("%{wks.location}/Build/Lib/%{cfg.buildcfg}-%{cfg.system}-wayland")
        # NkXdgShellProtocol.cpp wraps xdg-shell-protocol.c (auto-picked by **.cpp)
        files([
            "src/NKWindow/Platform/Linux/**.h",
            "src/NKWindow/Platform/Wayland/**.cpp",
            "src/NKWindow/Platform/Wayland/**.h",
        ])
        links(_WAYLAND_LINKS)
        defines(_WAYLAND_DEFINES)

    # ===== macOS ==================================================================
    with filter("system:macOS"):
        usetoolchain("clang-native")
        files([
            "src/NKWindow/Platform/Cocoa/NkCocoaWindow.mm",
            "src/NKWindow/Platform/Cocoa/NkCocoaEventSystem.mm",
            "src/NKWindow/Platform/Cocoa/NkCocoaWindow.h",
            "src/NKWindow/Platform/Cocoa/NkCocoaEventSystem.h",
            "src/NKWindow/Platform/Cocoa/NkCocoaGamepad.h",
        ])
        frameworks(["Cocoa", "QuartzCore", "OpenGL", "Metal"])

    # ===== Android ================================================================
    with filter("system:Android"):
        usetoolchain("android-ndk")
        files([
            "src/NKWindow/Platform/Android/NkAndroidWindow.cpp",
            "src/NKWindow/Platform/Android/NkAndroidEventSystem.cpp",
            "src/NKWindow/Platform/Android/NkAndroidWindow.h",
            "src/NKWindow/Platform/Android/NkAndroidEventSystem.h",
            "src/NKWindow/Platform/Android/NkAndroidGamepad.h",
            "src/NKWindow/Platform/Android/NkAndroidDropTarget.h",
        ])
        links(["android", "log", "EGL", "GLESv3"])
        androidapplicationid("com.nkentseu.nkwindow")
        androidminsdk(24)
        androidtargetsdk(34)
        androidcompilesdk(34)
        androidabis(["armeabi-v7a", "arm64-v8a", "x86", "x86_64"])
        androidnativeactivity(True)

    # ===== iOS ====================================================================
    with filter("system:iOS"):
        files([
            "src/NKWindow/Platform/UIKit/NkUIKitWindow.mm",
            "src/NKWindow/Platform/UIKit/NkUIKitEventSystem.mm",
            "src/NKWindow/Platform/UIKit/NkUIKitWindow.h",
            "src/NKWindow/Platform/UIKit/NkUIKitEventSystem.h",
            "src/NKWindow/Platform/UIKit/NkUIKitGamepad.h",
        ])
        frameworks(["UIKit", "QuartzCore", "OpenGLES", "AVFoundation"])
        iosbundleid("com.nkentseu.nkwindow")
        iosversion("1.0")
        iosminsdk("14.0")
        iosbuildnumber(1)

    # ===== Web ====================================================================
    with filter("system:Web"):
        usetoolchain("emscripten")
        files([
            "src/NKWindow/Platform/Emscripten/NkEmscriptenWindow.cpp",
            "src/NKWindow/Platform/Emscripten/NkEmscriptenEventSystem.cpp",
            "src/NKWindow/Platform/Emscripten/NkEmscriptenWindow.h",
            "src/NKWindow/Platform/Emscripten/NkEmscriptenEventSystem.h",
            "src/NKWindow/Platform/Emscripten/NkEmscriptenDropTarget.h",
            "src/NKWindow/Platform/Emscripten/NkEmscriptenGamepad.h",
        ])
        emscripteninitialmemory(32)

    # ===== HarmonyOS ==============================================================
    with filter("system:HarmonyOS"):
        defines(["NKENTSEU_FORCE_WINDOWING_NOOP_ONLY"])
        files([
            "src/NKWindow/Platform/Noop/NkNoopWindow.cpp",
            "src/NKWindow/Platform/Noop/NkNoopEventSystem.cpp",
            "src/NKWindow/Platform/Noop/NkNoopWindow.h",
            "src/NKWindow/Platform/Noop/NkNoopEventSystem.h",
            "src/NKWindow/Platform/Noop/NkNoopGamepad.h",
        ])
        links(["log", "EGL", "GLESv3"])

    # ===== UWP ====================================================================
    with filter("system:UWP || system:Windows && options:windows-runtime=uwp"):
        usetoolchain("xbox-clang")
        defines(["NKENTSEU_PLATFORM_UWP"])
        files([
            "src/NKWindow/Platform/UWP/NkUWPWindow.cpp",
            "src/NKWindow/Platform/UWP/NkUWPEventSystem.cpp",
            "src/NKWindow/Platform/UWP/NkUWPWindow.h",
            "src/NKWindow/Platform/UWP/NkUWPEventSystem.h",
            "src/NKWindow/Platform/UWP/NkUWPGamepad.h",
        ])
        links(["d3d12", "dxgi", "dxguid", "windowsapp"])

    # ===== Xbox ===================================================================
    with filter("system:XboxSeries || system:XboxOne"):
        usetoolchain("xbox-clang")
        defines(["NKENTSEU_PLATFORM_XBOX"])
        files([
            "src/NKWindow/Platform/Xbox/NkXboxWindow.cpp",
            "src/NKWindow/Platform/Xbox/NkXboxEventSystem.cpp",
            "src/NKWindow/Platform/Xbox/NkXboxWindow.h",
            "src/NKWindow/Platform/Xbox/NkXboxEventSystem.h",
            "src/NKWindow/Platform/Xbox/NkXboxGamepad.h",
        ])
        links(["d3d12", "dxgi", "dxguid", "xgameruntime"])

    with filter("system:XboxSeries"):
        defines(["NKENTSEU_PLATFORM_XBOX_SERIES"])

    with filter("system:XboxOne"):
        defines(["NKENTSEU_PLATFORM_XBOXONE"])

    with filter("config:Debug"):
        defines(["_DEBUG", "DEBUG"])
        optimize("Off")
        symbols(True)
    with filter("config:Release"):
        defines(["NDEBUG", "RELEASE"])
        optimize("Speed")
        symbols(False)

    # Tests unitaires (desktop uniquement)
    with filter("(system:Linux || system:macOS || (system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne)) && !system:Android && !system:iOS && !system:Web"):
        with test():
            testfiles(["tests/**.cpp"])
            with filter("system:Linux && options:linux-backend=wayland"):
                defines(["NKENTSEU_FORCE_WINDOWING_WAYLAND_ONLY"])
                links(_WAYLAND_TEST_LINKS)
            with filter("system:Linux && options:linux-backend=xcb"):
                defines(["NKENTSEU_FORCE_WINDOWING_XCB_ONLY"])
                links(["pthread", "xcb", "xcb-image", "xcb-icccm", "xcb-randr", "xcb-xfixes", "X11-xcb", "xkbcommon", "xkbcommon-x11"])
            with filter("system:Linux && options:linux-backend=xlib || system:Linux && !options:linux-backend && !options:headless"):
                defines(["NKENTSEU_FORCE_WINDOWING_XLIB_ONLY"])
                links(["pthread", "X11"])
