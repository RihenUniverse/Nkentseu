// triangle.vert.sw.sksl — Stage VERTEX uniquement
// Correspond à struct Vertex { NkVec2f position; NkVec3f color; };

@location(0) in vec2 aPosition;
@location(1) in vec3 aColor;

@location(0) out vec3 vColor;

@stage(vertex)
@entry
void vert_main() {
    vColor = aColor;
    gl_Position = vec4(aPosition, 0.0, 1.0);
}