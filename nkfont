        struct NkFontDataSpan {
            const nkft_uint8* data = nullptr;
            nkft_size         size = 0;

            bool IsValid(nkft_size offset, nkft_size len = 1) const {
                return data && (offset + len) <= size;
            }

            const nkft_uint8* At(nkft_size offset) const {
                return data + offset;
            }
