            free(texPixels);
            texPixels = nullptr;
        }
        if (mTexPixelsRGBA) {
            free(mTexPixelsRGBA);
            mTexPixelsRGBA = nullptr;
        }
        texWidth = 0;
        texHeight = 0;
        texReady = false;
