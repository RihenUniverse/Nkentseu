            static void SortEdges(Edge* e, nkft_uint32 n) {
                for (nkft_uint32 i = 1; i < n; ++i) {
                    Edge t = e[i];
                    nkft_int32 j = (nkft_int32)i - 1;
                    while (j >= 0 && e[j].y0 > t.y0) {
                        e[j + 1] = e[j];
                        --j;
                    }
                    e[j + 1] = t;
                }
            }

