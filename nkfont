    void NkFontAtlas::Clear() {
        ClearTexData();
        for (nkft_uint32 i = 0; i < fontCount; ++i) {
            if (fonts[i]) {
                delete fonts[i];
                fonts[i] = nullptr;
            }
        }
        fontCount = 0;
        for (nkft_uint32 i = 0; i < NK_FONT_ATLAS_MAX_FONTS; ++i) {
            if (fontDataBufs[i]) {
                free(fontDataBufs[i]);
                fontDataBufs[i] = nullptr;
            }
        }
        customRectCount = 0;
        texReady = false;
    }

    void NkFontAtlas::ClearTexData() {
