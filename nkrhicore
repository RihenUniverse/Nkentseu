        NK_UNIFORM_BUFFER  = 1 << 2,  // Constant Buffer
        NK_STORAGE_BUFFER  = 1 << 3,  // SSBO / UAV Buffer
        NK_SHADER_RESOURCE = 1 << 4,  // Texture SRV / Buffer SRV
        NK_UNORDERED_ACCESS= 1 << 5,  // UAV / Storage Image
