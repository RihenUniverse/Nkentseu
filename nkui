        static inline uint8 Reverse6Bits(uint8 x) noexcept {
            // Inverse les 6 premiers bits (bit0 <-> bit5, bit1 <-> bit4, bit2 <-> bit3)
            return ((x & 0x20) >> 5) | ((x & 0x10) >> 3) | ((x & 0x08) >> 1) |
                   ((x & 0x04) << 1) | ((x & 0x02) << 3) | ((x & 0x01) << 5);
        }

