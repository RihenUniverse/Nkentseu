        void NkUIDrawList::AddBezierCubic(NkVec2 p0,NkVec2 p1,NkVec2 p2,NkVec2 p3,
                                            NkColor col,float32 thickness,int32 segs) noexcept {
            PathClear(); PathMoveTo(p0);
