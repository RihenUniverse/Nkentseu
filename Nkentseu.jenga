    # // ---------------------------------------------------------------------------
    # // BlitWin32 : RGBA → BGRA + StretchDIBits
    # // ---------------------------------------------------------------------------

    # void NkSoftwareRendererImpl::BlitWin32(const NkSurfaceDesc& sd,
    #                                         NkU32 w, NkU32 h) {
    # #if defined(NKENTSEU_FAMILY_WINDOWS)
