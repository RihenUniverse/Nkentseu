GENERATED :=
OBJECTS :=

GENERATED += $(OBJDIR)/Unitest.o
GENERATED += $(OBJDIR)/UnitestCase.o
GENERATED += $(OBJDIR)/UnitestInfos.o
GENERATED += $(OBJDIR)/pch.o
